{
  "name": "@kellen/deno-mcp",
  "version": "0.1.0",
  "exports": {
    ".": "./mod.ts",
    "./cli": "./cli.ts",
    "./log": "./src/util/log.ts"
  },
  "tasks": {
    "dev": "deno run --watch examples/echo_server.ts",
    "test": "deno test --allow-run=deno --allow-read=./",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "install-cli": "deno install --allow-run -n deno-mcp ./cli.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "zod": "npm:zod@^3.25.76",
    "zod-to-json-schema": "npm:zod-to-json-schema@^3.25.2"
  },
  "permissions": {
    "mcp": {
      "read": ["./"],
      "env": true
    }
  },
  "fmt": {
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
